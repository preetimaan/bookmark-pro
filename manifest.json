{
  "manifest_version": 3,
  "name": "Bookmark Cleanup",
  "version": "0.2.0",
  "description": "Clean bookmarks: find duplicates, remove empty folders, merge folders, check broken links.",
  "permissions": ["bookmarks", "storage"],
  "optional_host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Bookmark Cleanup"
  },
  "options_ui": {
    "page": "manager.html",
    "open_in_tab": true
  }
}
